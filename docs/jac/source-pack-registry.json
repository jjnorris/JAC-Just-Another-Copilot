    ],
    "hook_contracts": [
      "docs/jac/hook-contracts/assumption-recorder/hook.json",
      "docs/jac/hook-contracts/context-budgeter/hook.json",
      "docs/jac/hook-contracts/dependency-risk/hook.json",
      "docs/jac/hook-contracts/error-occurred/hook.json",
      "docs/jac/hook-contracts/extension-surface-guard/hook.json",
      "docs/jac/hook-contracts/review-gate/hook.json",
      "docs/jac/hook-contracts/secrets-scanner/hook.json",
      "docs/jac/hook-contracts/session-start/hook.json",
      "docs/jac/hook-contracts/structured-output/hook.json",
      "docs/jac/hook-contracts/telemetry-emitter/hook.json",
      "docs/jac/hook-contracts/tool-guardian/hook.json"
    ]
  },
  "internal_role": "Supporting-canon registry and adapter inventory. Not a GitHub Copilot package manifest.",
  "primary_activation": {
    "verified_native_surfaces": [
      ".github/copilot-instructions.md",
      ".github/instructions/*.instructions.md",
      "AGENTS.md",
      ".github/skills/<name>/SKILL.md",
      ".github/hooks/*.json",
      ".github/agents/*.agent.md"
    ],
    "supporting_canon_root": "docs/jac"
  }
}
