    ],
    "event_contracts": [
      "docs/jac/event-contracts/agent-trace.schema.json",
      "docs/jac/event-contracts/correctness-events.schema.json",
      "docs/jac/event-contracts/memory-events.schema.json",
      "docs/jac/event-contracts/review-events.schema.json",
      "docs/jac/event-contracts/tool-events.schema.json"
    ],
    "docs": [
      "docs/jac/design-rationale.md",
      "docs/jac/extension-boundaries.md",
