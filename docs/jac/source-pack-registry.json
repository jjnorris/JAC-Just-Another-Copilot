{
  "schema_version": "jac-portable-manifest-v1",
  "name": "jac",
  "display_name": "JAC",
  "version": "0.1.0",
  "kind": "supporting-canon-registry",
  "public_persona": "small rules-and-notes pack",
  "summary": "Registry metadata for the JAC supporting canon and its native GitHub Copilot adapter files.",
  "compatibility_notes": {
    "native_github_copilot_package_schema_verified": false,
    "native_hooks_verified": true,
    "native_skills_verified": true,
    "native_workflows_verified": false,
    "user_scoped_install_verified": false,
    "notes": [
      "Use this registry as human-maintained inventory metadata for the JAC supporting canon.",
      "The primary native activation layer for this repo lives in .github/ plus AGENTS.md.",
      "Skills and hooks are now shipped through documented native GitHub Copilot locations, while the longer rationale stays under docs/jac/."
    ]
  },
  "activation_summary": {
    "user_scoped_activation": "optional; place files under ~/.copilot/ in supported environments",
    "workspace_override": "supported as a design pattern",
    "modes": [
      "always-on",
      "model-decision",
      "glob-pattern"
    ],
    "fallback": "manual use of instructions, workflows, templates, and docs"
  },
  "optional_features": {
    "semantic_memory": "optional and bounded",
    "native_hook_execution": "documented native surface in agent-capable flows",
    "native_skill_registration": "documented native surface in agent-capable flows",
    "slash_like_workflow_commands": "adapter-needed",
    "structured_trace_export": "portable with adapter or manual artifact generation"
  },
  "canonical_boundaries": {
    "authority_pack": [
      "policy",
      "planning rules",
      "verification rules",
      "memory rules",
      "gate logic",
      "truth rules"
    ],
    "surface": [
      "display",
      "relay",
      "commands",
      "focused UX",
      "local task and test integration"
    ],
    "tools": [
      "bounded work under least privilege"
    ],
    "state": [
      "repo truth",
      "explicit memory records",
      "trace artifacts"
    ]
  },
  "file_registry": {
    "repo_readme": "README.md",
    "install": "install.md",
    "compatibility": "compatibility.md",
    "agents": "AGENTS.md",
    "agent_profiles": [
      ".github/agents/jac.agent.md"
    ],
    "copilot_instructions": ".github/copilot-instructions.md",
    "path_instructions": [
      ".github/instructions/core.instructions.md",
      ".github/instructions/review.instructions.md",
      ".github/instructions/security.instructions.md",
      ".github/instructions/tests.instructions.md"
    ],
    "native_hooks": [
      ".github/hooks/assumption-recorder.json",
      ".github/hooks/context-budgeter.json",
      ".github/hooks/dependency-risk.json",
      ".github/hooks/error-occurred.json",
      ".github/hooks/extension-surface-guard.json",
      ".github/hooks/review-gate.json",
      ".github/hooks/secrets-scanner.json",
      ".github/hooks/session-start.json",
      ".github/hooks/structured-output.json",
      ".github/hooks/telemetry-emitter.json",
      ".github/hooks/tool-guardian.json"
    ],
    "hook_scripts": [
      ".github/hooks/scripts/jac_hook.py"
    ],
    "native_skills": [
      ".github/skills/autoresearch/SKILL.md",
      ".github/skills/compliance-audit/SKILL.md",
      ".github/skills/correctness-contract/SKILL.md",
      ".github/skills/doublecheck/SKILL.md",
      ".github/skills/extension-boundary/SKILL.md",
      ".github/skills/failure-triage/SKILL.md",
      ".github/skills/intake-clarifier/SKILL.md",
      ".github/skills/memory-manager/SKILL.md",
      ".github/skills/migration-safety/SKILL.md",
      ".github/skills/pattern-library/SKILL.md",
      ".github/skills/plan-review/SKILL.md",
      ".github/skills/repo-onboarding/SKILL.md",
      ".github/skills/secret-vault-awareness/SKILL.md",
      ".github/skills/trace-reporter/SKILL.md",
      ".github/skills/verifier-bridge/SKILL.md"
    ],
    "canon_readme": "docs/jac/README.md",
    "canon_instructions": "docs/jac/instructions.md",
    "rules": [
      "docs/jac/rules/00-core-role.md",
      "docs/jac/rules/01-repo-truth.md",
      "docs/jac/rules/02-boundaries.md",
