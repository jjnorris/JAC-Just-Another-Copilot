{
  "schema_version": "jac-inventory-v1",
  "name": "jac",
  "display_name": "JAC",
  "version": "0.1.0",
  "kind": "maintenance-inventory",
  "summary": "Inventory metadata for JAC's repo-scoped files and supporting reference docs.",
  "compatibility_notes": {
    "native_github_copilot_package_schema_verified": false,
    "native_hooks_verified": true,
    "native_skills_verified": true,
    "native_workflows_verified": false,
    "user_scoped_install_verified": false,
    "notes": [
      "Use this file as human-maintained inventory metadata for JAC.",
      "The repo-scoped GitHub Copilot files live under .github/ plus AGENTS.md.",
      "The longer reference docs live under docs/jac/."
    ]
  },
  "activation_summary": {
    "user_scoped_activation": "optional in supported environments; place files under ~/.copilot/ where GitHub documents that location",
    "cross_project_reuse": "copy the repo-scoped files first, then carry docs/jac/ as the longer reference set",
    "modes": [
      "always-on",
      "model-decision",
      "glob-pattern"
    ],
    "fallback": "manual use of instructions, workflows, templates, and docs"
  },
  "optional_features": {
    "semantic_memory": "optional and bounded",
    "native_hook_execution": "documented native surface in agent-capable flows",
    "native_skill_registration": "documented native surface in agent-capable flows",
    "markdown_workflow_use": "manual fallback or environment-specific tooling",
    "structured_trace_export": "manual artifact generation or environment-specific tooling"
  },
  "scope_boundaries": {
    "repo_scoped_files": "Files under .github/ plus AGENTS.md",
    "reference_docs": "Long-form docs under docs/jac/",
    "manual_fallback": "Read the repo-scoped files and docs directly when automatic loading is unavailable"
  },
  "file_registry": {
    "repo_readme": "README.md",
    "install": "install.md",
    "compatibility": "compatibility.md",
