{
  "schema_version": "jac-inventory-v2",
  "name": "jack",
  "display_name": "JACK",
  "version": "0.1.0",
  "kind": "maintenance-inventory",
  "summary": "Maintenance inventory for JACK's anchor files, file classes, and validation targets.",
  "purpose": {
    "why_this_exists": [
      "Record the canonical roots and file classes that make up JACK.",
      "Give maintainers one place to validate path-sensitive claims.",
      "Reduce drift between repo-scoped files and the longer docs in docs/jack/."
    ],
    "what_this_is_not": [
      "Not a GitHub Copilot package manifest.",
      "Not a runtime feature descriptor consumed by GitHub.",
      "Not a complete file-by-file registry that must change every time a single skill or doc is added."
    ]
  },
  "scopes": {
    "repo_scoped_roots": [
      ".github/",
      "AGENTS.md",
      "README.md",
      "install.md",
      "compatibility.md"
    ],
    "reference_root": "docs/jack/",
    "user_scoped_equivalents": [
      "$HOME/.copilot/copilot-instructions.md",
      "~/.copilot/skills/",
      "~/.copilot/agents/"
    ],
    "not_claimed": [
      "a user-scoped hooks directory",
      "native execution of Markdown workflows",
      "native consumption of this inventory file"
    ]
  },
  "anchor_files": {
    "repo_readme": "README.md",
    "install": "install.md",
    "compatibility": "compatibility.md",
    "agent_notes": "AGENTS.md",
    "repo_instructions": ".github/copilot-instructions.md",
    "reference_readme": "docs/jack/README.md",
    "design_rationale": "docs/jack/design-rationale.md",
    "reference_instructions": "docs/jack/instructions.md",
    "support_matrix": "docs/jack/support-matrix.md",
    "install_scopes": "docs/jack/install-scopes.md",
    "lite_profile": "docs/jack/lite-profile.md"
  },
  "patterns": {
    "path_instructions": [
      ".github/instructions/**/*.instructions.md"
    ],
    "skills": [
      ".github/skills/*/SKILL.md"
    ],
    "hooks": [
      ".github/hooks/*.json"
    ],
    "hook_scripts": [
      ".github/hooks/scripts/*.py"
    ],
    "agent_profiles": [
      ".github/agents/*.agent.md"
    ],
    "rules": [
      "docs/jack/rules/*.md"
    ],
    "workflows": [
      "docs/jack/workflows/*.md"
    ],
    "templates": [
      "docs/jack/templates/*"
    ],
    "event_contracts": [
      "docs/jack/event-contracts/*.json"
    ],
    "hook_contracts": [
      "docs/jack/hook-contracts/*/hook.json"
    ],
    "examples": [
      "docs/jack/examples/*"
    ],
    "support_docs": [
      "docs/jack/*.md"
    ]
  },
  "support_claims": {
    "documented_repo_surfaces": [
      ".github/copilot-instructions.md",
      ".github/instructions/**/*.instructions.md",
      "AGENTS.md",
      ".github/skills/*/SKILL.md",
      ".github/hooks/*.json",
      ".github/agents/*.agent.md"
    ],
    "manual_fallback": [
      "docs/jack/rules/*.md",
      "docs/jack/workflows/*.md",
      "docs/jack/templates/*",
      "docs/jack/examples/*",
      "docs/jack/hook-contracts/*/hook.json"
    ],
    "environment_specific": [
      "skill loading outside agent-capable flows",
      "hook execution outside documented coding-agent and CLI contexts",
      "custom agent availability by client"
    ]
  },
  "validation_targets": {
    "path_reference_docs": [
      "README.md",
      "install.md",
      "compatibility.md",
      "AGENTS.md",
      ".github/copilot-instructions.md",
      "docs/jack/README.md",
      "docs/jack/design-rationale.md",
      "docs/jack/install-scopes.md",
      "docs/jack/support-matrix.md",
      "docs/jack/hook-payloads.md",
      "docs/jack/lite-profile.md",
      "docs/jack/hook-contract-schema-families.md",
      "docs/jack/hook-enforcement-truth-matrix.md"
    ],
    "path_reference_json_patterns": [
      "docs/jack/hook-contracts/*/hook.json"
    ]
  },
  "maintenance": {
    "update_when": [
      "a canonical root changes",
      "a new native file class is introduced",
      "a docs subtree is renamed",
      "support-claim boundaries change materially"
    ],
    "validation": [
      "anchor files still exist",
      "glob patterns still match the expected file classes",
      "repo-scoped files and docs/jack/ still agree about scope language",
      "no stale path references survive a move or rename",
      "claims still match current official GitHub docs"
    ],
    "preferred_style": [
      "track classes of files with patterns rather than enumerating every file",
      "keep this file stable across ordinary content additions",
      "use support-matrix.md and install-scopes.md for nuanced prose, not this inventory"
    ]
  }
}
