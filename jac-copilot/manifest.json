{
  "schema_version": "jac-portable-manifest-v1",
  "name": "jac-copilot",
  "display_name": "JAC",
  "version": "0.1.0",
  "kind": "portable-authority-pack",
  "public_persona": "small rules-and-notes pack",
  "summary": "Portable GitHub Copilot authority pack with global rules, workspace override guidance, workflows, skills, pseudo-hooks, templates, and trace contracts.",
  "compatibility_notes": {
    "native_github_copilot_package_schema_verified": false,
    "native_hooks_verified": false,
    "native_skills_verified": false,
    "native_workflows_verified": false,
    "global_user_install_verified": false,
    "notes": [
      "Use this manifest as portable metadata unless your environment proves a richer native surface.",
      "The instructions and workflow documents remain authoritative even with no adapter."
    ]
  },
  "activation_summary": {
    "global_user_scope": "conceptual and adapter-dependent",
    "workspace_override": "supported as a design pattern",
    "modes": [
      "always-on",
      "model-decision",
      "glob-pattern"
    ],
    "fallback": "manual use of instructions, workflows, templates, and docs"
  },
  "optional_features": {
    "semantic_memory": "optional and bounded",
    "native_hook_execution": "adapter-needed",
    "native_skill_registration": "adapter-needed",
    "slash_like_workflow_commands": "adapter-needed",
    "structured_trace_export": "portable with adapter or manual artifact generation"
  },
  "canonical_boundaries": {
    "authority_pack": [
      "policy",
      "planning rules",
      "verification rules",
      "memory rules",
      "gate logic",
      "truth rules"
    ],
    "surface": [
      "display",
      "relay",
      "commands",
      "focused UX",
      "local task and test integration"
    ],
    "tools": [
      "bounded work under least privilege"
    ],
    "state": [
      "repo truth",
      "explicit memory records",
      "trace artifacts"
    ]
  },
  "file_registry": {
    "instructions": "instructions.md",
    "install": "install.md",
    "compatibility": "compatibility.md",
    "readme": "README.md",
    "rules": [
      "rules/00-core-role.md",
      "rules/01-repo-truth.md",
      "rules/02-boundaries.md",
      "rules/03-execution-loop.md",
      "rules/04-ambiguity-policy.md",
      "rules/05-memory-policy.md",
      "rules/06-tool-governance.md",
      "rules/07-output-guardrails.md",
      "rules/08-research-policy.md",
      "rules/09-compliance-security-license.md",
      "rules/10-correctness-contracts.md",
      "rules/11-review-policy.md",
      "rules/12-reporting-and-traces.md",
      "rules/13-stop-conditions.md"
    ],
    "workflows": [
      "workflows/bounded-implementation.md",
      "workflows/bugfix-with-proof.md",
      "workflows/compliance-triage.md",
      "workflows/intake-and-clarify.md",
      "workflows/plan-review.md",
      "workflows/research-with-citations.md",
      "workflows/rollback-and-recovery.md",
      "workflows/safe-refactor.md",
      "workflows/secret-handling.md",
      "workflows/verify-before-claim.md"
    ],
    "skills": [
      "skills/autoresearch/skill.json",
      "skills/compliance-audit/skill.json",
      "skills/correctness-contract/skill.json",
      "skills/doublecheck/skill.json",
      "skills/extension-boundary/skill.json",
      "skills/intake-clarifier/skill.json",
      "skills/memory-manager/skill.json",
      "skills/pattern-library/skill.json",
      "skills/plan-review/skill.json",
      "skills/secret-vault-awareness/skill.json",
      "skills/trace-reporter/skill.json",
      "skills/verifier-bridge/skill.json"
    ],
    "hooks": [
      "hooks/assumption-recorder/hook.json",
      "hooks/context-budgeter/hook.json",
      "hooks/dependency-risk/hook.json",
      "hooks/extension-surface-guard/hook.json",
      "hooks/review-gate/hook.json",
      "hooks/secrets-scanner/hook.json",
      "hooks/structured-output/hook.json",
      "hooks/telemetry-emitter/hook.json",
      "hooks/tool-guardian/hook.json"
    ],
    "event_contracts": [
      "event-contracts/agent-trace.schema.json",
      "event-contracts/correctness-events.schema.json",
      "event-contracts/memory-events.schema.json",
      "event-contracts/review-events.schema.json",
      "event-contracts/tool-events.schema.json"
    ],
    "templates": [
      "templates/assumption-record.json",
      "templates/clarification-request.json",
      "templates/correctness-contract.json",
      "templates/plan-review-comment.json",
      "templates/rollback-note.md",
      "templates/usage-summary.json",
      "templates/verification-report.json"
    ],
    "docs": [
      "docs/design-rationale.md",
      "docs/extension-boundaries.md",
      "docs/review-and-approval-model.md",
      "docs/rotation-runbook.md",
      "docs/secret-handling-model.md",
      "docs/trace-taxonomy.md"
    ],
    "examples": [
      "examples/correctness-contract-example.json",
      "examples/review-comment-example.md",
      "examples/workflow-example.md",
      "examples/workspace-rule-example.md"
    ]
  }
}
